{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Blog: New post",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/blog.ps1",
        "new",
        "${input:postTitle}"
      ],
      "problemMatcher": []
    },
    {
      "label": "Blog: Local preview",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/blog.ps1",
        "dev"
      ],
      "problemMatcher": [],
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Blog: Build check",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/blog.ps1",
        "build"
      ],
      "problemMatcher": []
    },
    {
      "label": "Blog: Publish",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/scripts/blog.ps1",
        "publish",
        "${input:commitMessage}"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "postTitle",
      "type": "promptString",
      "description": "New post title",
      "default": "新的学习记录"
    },
    {
      "id": "commitMessage",
      "type": "promptString",
      "description": "Commit message",
      "default": "blog: update"
    }
  ]
}
